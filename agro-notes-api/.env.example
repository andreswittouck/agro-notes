# ============================================================
# AgroNotes · Backend API (.env)
# ============================================================
# Copiá este archivo a `.env` y completá los valores.
# NUNCA commitees `.env`, `.env.prod` ni variantes — están en .gitignore.
# ============================================================

# ---------- General ----------
NODE_ENV=development
TZ=America/Argentina/Cordoba

# ---------- HTTP ----------
PORT=4000
# Lista separada por comas de orígenes permitidos (sin trailing slash).
# En prod, NUNCA uses *.
CORS_ORIGIN=http://localhost:3000

# ---------- Base de datos (Postgres) ----------
DB_HOST=localhost
DB_PORT=15432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=agro
# Si tu proveedor obliga SSL (Render, Supabase, Neon), poné true.
DB_SSL=false

# ---------- TypeORM ----------
# synchronize=true crea/actualiza el schema en caliente.
# OK para desarrollo local. En prod, usar migraciones y dejarlo en false.
TYPEORM_SYNC=true
TYPEORM_LOGGING=false
TYPEORM_DROP_SCHEMA=false
TYPEORM_RUN_MIGRATION=false

# ---------- Firebase Admin (server) ----------
# Usá UNA de estas dos opciones:
#
# Opción A (recomendada en Render/Vercel/serverless):
#   Pegá el contenido JSON del service account en una sola línea.
#   Consola de Firebase → Project settings → Service accounts →
#   "Generate new private key".
# FIREBASE_ADMIN_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n", ...}
#
# Opción B (desarrollo local con archivo):
#   Path al JSON descargado. Agregar el archivo a .gitignore.
# FIREBASE_ADMIN_KEY_PATH=./firebase-admin-key.json

# ---------- Autorización ----------
# Lista separada por comas de emails autorizados a usar la API.
# Si queda vacía, la API DENIEGA todos los requests (fail-closed).
AUTHORIZED_EMAILS=andreswittouck@gmail.com

# Lista separada por comas de emails que tienen privilegios de admin.
# Pueden ver TODAS las notas (con ?scope=all), revocar cualquier share,
# y modificar/borrar notas de otros usuarios.
ADMIN_EMAILS=andreswittouck@gmail.com

# ---------- JWT (opcional, solo si usás tu propio JWT además de Firebase) ----------
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
