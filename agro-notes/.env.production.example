# ============================================================
# AgroNotes · Frontend (Next.js) · PRODUCCIÓN
# ============================================================
# Cómo usarlo en Vercel:
#   1. Copiá este archivo a `.env.production` (queda en .gitignore).
#   2. Reemplazá NEXT_PUBLIC_API_BASE por la URL real de Render.
#      (Las demás ya tienen los valores del proyecto Firebase.)
#   3. En Vercel dashboard → tu proyecto → Settings → Environment
#      Variables → botón "..." arriba a la derecha de la lista →
#      "Import .env" → seleccioná tu archivo o pegá el contenido.
#   4. En el diálogo, marcá los entornos donde aplican (mínimo:
#      Production. Recomendado: Production + Preview + Development).
#   5. Guardá. Vercel redeploya solo en el siguiente push, o
#      forzá "Redeploy" desde el dashboard.
#
# IMPORTANTE: en Vercel TODO lo que arranca con NEXT_PUBLIC_*
# viaja al navegador. Nunca pongas secretos del backend acá.
# ============================================================

# URL pública del backend en Render. SIN barra al final.
# Ej: https://agro-notes-api.onrender.com
NEXT_PUBLIC_API_BASE=https://REPLACE-WITH-RENDER-BACKEND-URL.onrender.com

# ---------- Firebase (cliente) ----------
# Los valores se sacan de:
# Firebase Console → Project settings → "Your apps" → tu app web →
# "SDK setup and configuration". Estos son los del proyecto
# agro-notes-47547 que ya está configurado en dev.
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyCBmUEOTT_r21_at61azBpmKIquul2kC2o
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=agro-notes-47547.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=agro-notes-47547
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=agro-notes-47547.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=970892100417
NEXT_PUBLIC_FIREBASE_APP_ID=1:970892100417:web:87c619051ad0489a3257c0
